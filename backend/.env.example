# Environment Configuration Template for Academe
# Copy this to .env and fill in your values

# ==========================================
# LLM Configuration
# ==========================================
LLM_PROVIDER=gemini  # Options: gemini, claude, openai

# Required API Keys
GOOGLE_API_KEY=your_gemini_api_key_here         # Gemini — user-facing assistant
OPENAI_API_KEY=your_openai_api_key_here         # gpt-4o-mini — query rewriting, HyDE, RAGAS eval

# Optional — alternative primary LLM (replaces Gemini)
# ANTHROPIC_API_KEY=your_claude_api_key_here

# ==========================================
# Embedding Configuration
# ==========================================
# EMBEDDING_PROVIDER=openai              # Options: gemini, openai (recommended), sentence-transformers
# EMBEDDING_MODEL=text-embedding-3-small # OpenAI: 1536 dim. Gemini: 768 dim (100 req/min free tier limit)
# EMBEDDING_DIM=1536                     # OpenAI default; Gemini: 768

# ==========================================
# App Settings
# ==========================================
LOG_LEVEL=INFO

# ==========================================
# MongoDB Configuration
# ==========================================
MONGODB_URI=mongodb://admin:academe123@localhost:27017/
MONGODB_DB_NAME=academe

# ==========================================
# Pinecone Configuration
# ==========================================
# Use different index names per embedding model (dimension must match)
# academe = 768 dim (Gemini), academe-oai = 1536 dim (OpenAI)
PINECONE_API_KEY=your_key
PINECONE_ENVIRONMENT=your_env
PINECONE_INDEX_NAME=academe-oai

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==========================================
# Session Configuration
# ==========================================
SESSION_TIMEOUT_MINUTES=60
MAX_SESSIONS_PER_USER=5

# ==========================================
# Celery Configuration (Background Tasks)
# ==========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ==========================================
# Evaluation (RAGAS)
# ==========================================
# EVAL_USER_ID=user_id_with_indexed_documents  # Optional; auto-detected if unset

# ==========================================
# Reranker (context precision)
# ==========================================
# RERANKER_MIN_SCORE=0.0  # Filter chunks below this score (BGE ~-10 to 10)